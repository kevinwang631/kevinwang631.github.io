---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}

      {% if page.cv_pdf %}
        <a
          {% if page.cv_pdf contains '://' %}
            href="{{ page.cv_pdf }}"
          {% else %}
            href="{{ page.cv_pdf | relative_url }}"
          {% endif %}
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
          aria-label="Open CV PDF"
          title="Open CV PDF"
        >
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>

    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    {{ content }}

    {% if page.cv_pdf %}
      <iframe
        {% if page.cv_pdf contains '://' %}
          src="{{ page.cv_pdf }}"
        {% else %}
          src="{{ page.cv_pdf | relative_url }}"
        {% endif %}
        width="100%"
        height="900px"
        style="border: 1px solid #ddd; border-radius: 4px;"
      >
      </iframe>
    {% endif %}
  </article>
</div>
